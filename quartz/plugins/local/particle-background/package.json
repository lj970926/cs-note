{
  "name": "@lj970926/particle-background",
  "version": "0.1.0",
  "description": "Subtle canvas particle background component for Quartz",
  "type": "module",
  "license": "MIT",
  "files": [
    "dist",
    "README.md"
  ],
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    },
    "./components": {
      "types": "./dist/components/index.d.ts",
      "import": "./dist/components/index.js"
    },
    "./package.json": "./package.json"
  },
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "sideEffects": false,
  "scripts": {
    "build": "tsup",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "@quartz-community/types": "github:quartz-community/types",
    "@quartz-community/utils": "github:quartz-community/utils"
  },
  "peerDependencies": {
    "preact": "^10.0.0"
  },
  "peerDependenciesMeta": {
    "preact": {
      "optional": false
    }
  },
  "devDependencies": {
    "sass": "^1.97.3",
    "tsup": "^8.5.0",
    "typescript": "^5.9.3"
  },
  "engines": {
    "node": ">=22",
    "npm": ">=10.9.2"
  },
  "quartz": {
    "name": "particle-background",
    "displayName": "Particle Background",
    "description": "A subtle non-interactive canvas particle background.",
    "category": "component",
    "version": "1.0.0",
    "quartzVersion": ">=5.0.0",
    "dependencies": [],
    "defaultOrder": 0,
    "defaultEnabled": true,
    "defaultOptions": {
      "particleCount": 56,
      "maxMobileParticles": 28,
      "maxLinkDistance": 140,
      "speed": 0.22,
      "opacity": 0.55,
      "mouseRadius": 190,
      "mouseStrength": 0.01
    },
    "components": {
      "ParticleBackground": {
        "displayName": "Particle Background",
        "defaultPosition": "beforeBody",
        "defaultPriority": 0
      }
    }
  }
}
